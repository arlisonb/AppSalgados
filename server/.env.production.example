# Produção VPS — porta 3000 em localhost (nginx na 443 faz o proxy)
PORT=3000
HOST=127.0.0.1
NODE_ENV=production
SERVE_WEB=false
PUBLIC_URL=https://iona.meuappagenda.com.br

SESSION_NAME=iona-salgados
